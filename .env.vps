# ── Hermes Agent — VPS Environment Variables ────────────────────────────────
# Copy this to .env and fill in your keys.
# The agent listens on port 8000 inside the container;
# docker-compose.yml maps it to port 8080 on the host.

# ── Required: at least one LLM provider key ─────────────────────────────────
FIREWORKS_API_KEY=fw_your_key_here
LLM_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ── Admin password for the setup page ───────────────────────────────────────
ADMIN_PASSWORD=change_this_to_a_strong_password

# ── Optional: Tool APIs ─────────────────────────────────────────────────────
# EXA_API_KEY=
# FIRECRAWL_API_KEY=
# FAL_KEY=
# HONCHO_API_KEY=
# GITHUB_TOKEN=

# ── Gateway security ────────────────────────────────────────────────────────
GATEWAY_ALLOW_ALL_USERS=true

# ── Terminal backend ────────────────────────────────────────────────────────
TERMINAL_ENV=local
TERMINAL_TIMEOUT=60
